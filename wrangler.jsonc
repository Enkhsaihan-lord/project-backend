		},
	],
	"r2_buckets": [
		{
			"binding": "R2_BUCKET",
			"bucket_name": "movie-images",
		},
	],
	"vars": {
		"R2_PUBLIC_URL": "https://pub-c62869c268894b90b7e977c831ef31b1.r2.dev",
	},
}
